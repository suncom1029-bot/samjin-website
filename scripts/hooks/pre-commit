#!/bin/bash

# Pre-commit hook: CLAUDE.md 업데이트 상기
# 중요 파일(PHP, JS, CSS)이 변경되면 CLAUDE.md도 함께 수정되었는지 확인

# 스테이징된 파일 목록 가져오기
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# 확인할 중요 파일 패턴
IMPORTANT_PATTERNS=("\.php$" "\.js$" "\.css$" "docker-compose.yml" "Dockerfile")

# 중요 파일이 변경되었는지 확인
IMPORTANT_CHANGED=false
for pattern in "${IMPORTANT_PATTERNS[@]}"; do
  if echo "$STAGED_FILES" | grep -qE "$pattern"; then
    IMPORTANT_CHANGED=true
    break
  fi
done

# CLAUDE.md가 스테이징되었는지 확인
CLAUDE_MD_STAGED=$(echo "$STAGED_FILES" | grep -c "CLAUDE.md" || true)

# 중요 파일은 변경되었는데 CLAUDE.md는 변경되지 않았으면 경고
if [ "$IMPORTANT_CHANGED" = true ] && [ "$CLAUDE_MD_STAGED" -eq 0 ]; then
  echo ""
  echo "⚠️  WARNING: CLAUDE.md를 함께 업데이트했나요?"
  echo ""
  echo "다음 파일들이 변경되었습니다:"
  echo "$STAGED_FILES" | grep -E "\.(php|js|css)$|docker-compose|Dockerfile" | sed 's/^/  - /'
  echo ""
  echo "📝 CLAUDE.md 수정 체크리스트:"
  echo "  ☐ Project Structure 업데이트 (새 디렉토리/파일)"
  echo "  ☐ Key Files 테이블 업데이트 (파일 역할 변경)"
  echo "  ☐ Common Tasks 업데이트 (새 작업 추가)"
  echo "  ☐ Notes 업데이트 (주의사항 변경)"
  echo ""
  echo "💡 CLAUDE.md를 수정 후 'git add CLAUDE.md'를 실행하세요."
  echo ""

  # 사용자가 강제 진행을 원하면: git commit --no-verify
  read -p "계속 진행할까요? (y/n) " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    exit 1
  fi
fi

exit 0
